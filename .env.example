WORDPRESS_PORT=8080
WORDPRESS_DB_NAME=gdd_wordpress
WORDPRESS_DB_USER=gdd_wp
WORDPRESS_DB_PASSWORD=gdd_wp_password
WORDPRESS_DB_ROOT_PASSWORD=gdd_root_password

# Astro / WordPress CMS
WP_API_URL=http://localhost:8080/wp-json
PUBLIC_WP_SITE_URL=http://localhost:8080
WP_DEBUG_FETCH=false

# Public site URL (SEO, canonical, linki w mailu)
PUBLIC_SITE_URL=http://localhost:4321

# Stripe — test: https://dashboard.stripe.com/test/apikeys
# Produkt „Wprowadzenie do pięknego dźwięku”, 29,00 PLN → Price ID (price_…)
# LIVE (prod): prod_Uc4waClJR9aohA → price_1TcqmRQmgu7Kx2PRaMhMn0sU
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_WPROWADZENIE_DZWIEKU=price_REPLACE_ME

# E-mail transakcyjny (Resend) — WYMAGANE do wysyłki linku po zakupie
# Konto: https://resend.com → API Keys
# Lokalnie bez weryfikacji domeny użyj:
#   RESEND_API_KEY=re_...
#   EMAIL_FROM=onboarding@resend.dev
# Produkcja: zweryfikuj domenę i ustaw np. sklep@gospoda-dobrego-dzwieku.pl
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Ważność linku pobrania (godziny, jednorazowy link)
DOWNLOAD_TOKEN_TTL_HOURS=48
