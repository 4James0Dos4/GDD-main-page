---
import { homeHeroAssets, homeHeroData, siteMeta, heroVerticalMark } from "../../data/gddHome";
import ManaImage from "./ManaImage.astro";

const hero = homeHeroAssets.heroImage;
const descLines = homeHeroData.description
  .split(/\.\s+/)
  .map((s) => s.trim())
  .filter(Boolean)
  .map((s) => (s.endsWith(".") ? s : `${s}.`));
const line1 = descLines[0] ?? homeHeroData.description;
const line2 = descLines[1] ?? "";
---

<section
  class="mana-hero-cinematic relative min-h-[100svh] bg-black text-white"
  aria-labelledby="hero-main-title"
>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 top-16 z-0 mana-hero-media">
    <ManaImage
      src={hero}
      alt="Studiowy mikser i realizacja dźwięku"
      width={1280}
      height={853}
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      sizes="100vw"
      widths={[640, 960, 1280]}
      quality={75}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/55 to-black/25"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/20 to-transparent"></div>
    <div class="mana-grain absolute inset-0 opacity-[0.12] mix-blend-overlay" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 flex min-h-[100svh] flex-col">
    <div class="h-16 shrink-0" aria-hidden="true"></div>

    <div
      class="relative flex min-h-0 flex-1 flex-col justify-end px-5 pb-10 pt-6 sm:px-8 sm:pb-14 md:px-12 md:pb-16 lg:px-14"
    >
      <div class="flex min-h-[45vh] flex-1 flex-col items-stretch justify-end gap-8 md:flex-row md:items-end md:justify-between">
        <div
          class="mana-vertical-mark font-['Roboto_Condensed',sans-serif] font-bold uppercase tracking-[0.12em] text-white drop-shadow-[0_0_40px_rgba(0,0,0,0.9)] md:mb-0 md:self-end"
          style="writing-mode: vertical-rl; text-orientation: mixed; transform: rotate(180deg);"
          aria-hidden="true"
        >
          {heroVerticalMark}
        </div>

        <div class="max-w-xl flex-1 text-left md:max-w-[min(32rem,44vw)] md:text-right">
          <h1
            id="hero-main-title"
            class="font-display text-[clamp(1.75rem,4.5vw,3.25rem)] font-light leading-[1.08] tracking-tight text-white drop-shadow-md md:ml-auto"
            style="font-family: Melodrama, Georgia, serif;"
          >
            {homeHeroData.heading}
          </h1>
          <p class="mt-1 font-['Roboto',sans-serif] text-sm font-medium uppercase tracking-[0.12em] text-white md:ml-auto">
            {homeHeroData.subtitle}
          </p>
          <p class="mt-5 max-w-prose font-['Roboto',sans-serif] text-sm font-normal leading-relaxed text-white md:ml-auto md:text-base">
            {line1}
          </p>
          {
            line2 ? (
              <p class="mt-2 max-w-prose font-['Roboto',sans-serif] text-sm font-normal leading-relaxed text-white md:ml-auto md:text-base">
                {line2}
              </p>
            ) : null
          }
          <p class="mt-3 font-['Roboto',sans-serif] text-xs italic text-white/90 md:ml-auto">
            {siteMeta.siteMotto}
          </p>

          <div class="mt-8 flex flex-col items-stretch gap-3 sm:flex-row sm:justify-end md:ml-auto">
            <a
              href={homeHeroData.cta1Href}
              class="inline-flex items-center justify-center border border-white/55 bg-white/12 px-6 py-3 text-center font-['Roboto',sans-serif] text-xs font-semibold uppercase tracking-[0.2em] text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/22"
            >
              {homeHeroData.cta1Label}
            </a>
            <a
              href={homeHeroData.cta2Href}
              class="inline-flex items-center justify-center px-4 py-3 text-center font-['Roboto',sans-serif] text-xs font-semibold uppercase tracking-[0.22em] text-white underline decoration-white/50 underline-offset-4 transition-colors hover:decoration-white"
            >
              {homeHeroData.cta2Label} →
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Filtr musi trafić na <img> z ManaImage (osobny scope Astro). */
  .mana-hero-media :global(img) {
    filter: grayscale(1) contrast(1.12) brightness(0.88);
  }
  .mana-vertical-mark {
    font-size: clamp(3.5rem, 18vw, 8rem);
    line-height: 0.9;
  }
  .mana-grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
  }
</style>
