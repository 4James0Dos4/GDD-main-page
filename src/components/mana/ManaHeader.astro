---
import { siteMeta, navItems } from "../../data/gddHome";
import logo from "../../assets/gdd-logo-header.png";
import ManaImage from "./ManaImage.astro";

function linkAttrs(href: string, external?: boolean) {
  if (external || href.startsWith("http")) {
    return { target: "_blank" as const, rel: "noopener noreferrer" };
  }
  return {};
}
---

<header
  class="site-header fixed left-0 right-0 top-0 z-[1000] border-b border-white/10 bg-black transition-transform"
  id="top"
>
  <div
    class="container mx-auto flex h-16 max-w-[1300px] items-center justify-between gap-3 px-4 sm:px-6"
  >
    <a href="/" class="group flex min-w-0 shrink items-center gap-3 sm:gap-4" aria-label={siteMeta.siteName}>
      <span class="mana-header-logo-mark" aria-hidden="true">
        <ManaImage
          src={logo}
          alt=""
          width={88}
          height={93}
          widths={[44, 88, 104]}
          sizes="(min-width: 640px) 52px, 44px"
          quality={82}
          loading="eager"
          decoding="async"
          fetchpriority="low"
          class="h-full w-auto max-h-full object-contain"
        />
      </span>
      <span
        class="font-['Roboto_Condensed',sans-serif] text-lg font-bold uppercase leading-none tracking-tight text-white sm:text-xl"
      >
        Gospoda
      </span>
      <span class="hidden h-8 w-px shrink-0 bg-white/35 sm:block" aria-hidden="true"></span>
      <span
        class="hidden max-w-[14rem] font-['Roboto',sans-serif] text-[9px] font-light uppercase leading-snug tracking-[0.12em] text-white sm:block md:max-w-[18rem] md:text-[10px]"
      >
        {siteMeta.siteSubtitle} · {siteMeta.siteMotto}
      </span>
    </a>

    <nav class="mana-header-nav hidden items-center gap-0.5 lg:flex" aria-label="Główne">
      {
        navItems.map((item) =>
          item.children?.length ? (
            <div class="mana-header-nav__dropdown group relative">
              <button
                type="button"
                class="mana-header-nav__trigger"
                aria-haspopup="true"
                aria-expanded="false"
              >
                {item.label}
                <i class="fa-solid fa-chevron-down text-[0.5rem] opacity-70" aria-hidden="true"></i>
              </button>
              <ul class="mana-header-nav__submenu" role="menu">
                {
                  item.children.map((child) => (
                    <li role="none">
                      <a
                        href={child.href}
                        class="mana-header-nav__sublink"
                        role="menuitem"
                        aria-label={child.label}
                        {...linkAttrs(child.href, child.external)}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          ) : (
            <a href={item.href} class="mana-header-nav__link" aria-label={item.label}>
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <button
      type="button"
      id="mana-menu-trigger"
      class="mana-menu-trigger cursor-pointer p-2 text-white lg:hidden"
      aria-expanded="false"
      aria-controls="mana-mobile-menu"
      aria-label="Menu"
    >
      <i class="fa-solid fa-bars text-xl" aria-hidden="true"></i>
    </button>
  </div>

  <div
    id="mana-mobile-menu"
    class="mana-mobile-menu invisible fixed left-0 right-0 top-0 z-[999] max-h-0 overflow-hidden overflow-y-auto bg-black/95 pt-16 opacity-0 backdrop-blur-sm transition-all duration-300 lg:hidden"
  >
    <nav class="flex flex-col px-6 pb-10" aria-label="Menu mobilne">
      {
        navItems.map((item) =>
          item.children?.length ? (
            <details class="mana-mobile-nav__group border-b border-white/10">
              <summary class="mana-mobile-nav__summary">{item.label}</summary>
              <div class="pb-2 pl-3">
                {
                  item.children.map((child) => (
                    <a
                      href={child.href}
                      class="mana-mobile-nav__sublink"
                      aria-label={child.label}
                      {...linkAttrs(child.href, child.external)}
                    >
                      {child.label}
                    </a>
                  ))
                }
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class="mana-mobile-link border-b border-white/10 py-4 font-['Roboto',sans-serif] text-xs font-normal uppercase tracking-[0.2em] text-white/90 hover:text-white"
              aria-label={item.label}
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById("mana-menu-trigger");
    var menu = document.getElementById("mana-mobile-menu");
    if (!btn || !menu) return;

    function closeMenu() {
      menu.classList.remove("mana-mobile-menu--open");
      menu.style.maxHeight = "0";
      menu.style.opacity = "0";
      menu.style.visibility = "hidden";
      btn.setAttribute("aria-expanded", "false");
      var i = btn.querySelector("i");
      if (i) i.className = "fa-solid fa-bars text-xl";
    }

    btn.addEventListener("click", function () {
      var open = menu.classList.contains("mana-mobile-menu--open");
      if (open) {
        closeMenu();
      } else {
        menu.classList.add("mana-mobile-menu--open");
        menu.style.visibility = "visible";
        menu.style.opacity = "1";
        menu.style.maxHeight = "100vh";
        btn.setAttribute("aria-expanded", "true");
        var ic = btn.querySelector("i");
        if (ic) ic.className = "fa-solid fa-xmark text-xl";
      }
    });

    menu.querySelectorAll("a").forEach(function (a) {
      a.addEventListener("click", closeMenu);
    });

    document.querySelectorAll(".mana-header-nav__dropdown").forEach(function (dropdown) {
      var trigger = dropdown.querySelector(".mana-header-nav__trigger");
      if (!trigger) return;
      trigger.addEventListener("click", function (e) {
        e.stopPropagation();
        var open = dropdown.classList.contains("is-open");
        document.querySelectorAll(".mana-header-nav__dropdown.is-open").forEach(function (d) {
          if (d !== dropdown) {
            d.classList.remove("is-open");
            var t = d.querySelector(".mana-header-nav__trigger");
            if (t) t.setAttribute("aria-expanded", "false");
          }
        });
        dropdown.classList.toggle("is-open", !open);
        trigger.setAttribute("aria-expanded", open ? "false" : "true");
      });
    });

    document.addEventListener("click", function () {
      document.querySelectorAll(".mana-header-nav__dropdown.is-open").forEach(function (d) {
        d.classList.remove("is-open");
        var t = d.querySelector(".mana-header-nav__trigger");
        if (t) t.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>

<style>
  .mana-header-logo-mark {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    height: 2.75rem;
    width: auto;
  }

  .mana-header-logo-mark :global(img) {
    display: block;
    height: 100%;
    width: auto;
    max-height: 2.75rem;
    object-fit: contain;
    image-rendering: auto;
    filter: drop-shadow(0 1px 4px rgb(0 0 0 / 0.35));
    transition: filter 0.2s ease;
  }

  .group:hover .mana-header-logo-mark :global(img),
  .group:focus-visible .mana-header-logo-mark :global(img) {
    filter: drop-shadow(0 2px 8px rgb(0 0 0 / 0.4));
  }

  @media (min-width: 640px) {
    .mana-header-logo-mark {
      height: 3.25rem;
    }

    .mana-header-logo-mark :global(img) {
      max-height: 3.25rem;
    }
  }

  .mana-mobile-menu.mana-mobile-menu--open {
    visibility: visible;
  }

  .mana-header-nav__link,
  .mana-header-nav__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
    padding: 0.5rem 0.65rem;
    font-family: "Roboto", ui-sans-serif, system-ui, sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  @media (min-width: 1280px) {
    .mana-header-nav__link,
    .mana-header-nav__trigger {
      font-size: 11px;
      padding: 0.5rem 0.75rem;
    }
  }

  .mana-header-nav__link:hover,
  .mana-header-nav__trigger:hover,
  .mana-header-nav__dropdown.is-open .mana-header-nav__trigger {
    background: rgb(255 255 255 / 0.1);
    color: #fff;
  }

  .mana-header-nav__submenu {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 50;
    min-width: 13rem;
    margin: 0;
    padding: 0.35rem 0;
    list-style: none;
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: 0.25rem;
    background: rgb(0 0 0 / 0.96);
    box-shadow: 0 12px 32px -12px rgb(0 0 0 / 0.65);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.35rem);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s ease;
    pointer-events: none;
  }

  .mana-header-nav__dropdown:hover .mana-header-nav__submenu,
  .mana-header-nav__dropdown:focus-within .mana-header-nav__submenu,
  .mana-header-nav__dropdown.is-open .mana-header-nav__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mana-header-nav__sublink {
    display: block;
    padding: 0.55rem 1rem;
    font-family: "Roboto", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.88);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .mana-header-nav__sublink:hover {
    background: rgb(255 255 255 / 0.08);
    color: #fff;
  }

  .mana-mobile-nav__group {
    margin: 0;
  }

  .mana-mobile-nav__summary {
    cursor: pointer;
    list-style: none;
    padding: 1rem 0;
    font-family: "Roboto", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.9);
  }

  .mana-mobile-nav__summary::-webkit-details-marker {
    display: none;
  }

  .mana-mobile-nav__sublink {
    display: block;
    padding: 0.65rem 0;
    font-family: "Roboto", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.72);
    transition: color 0.2s ease;
  }

  .mana-mobile-nav__sublink:hover {
    color: #fff;
  }
</style>
