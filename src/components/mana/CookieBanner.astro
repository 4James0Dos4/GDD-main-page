<div
  id="cookie-banner"
  class="mana-cookie-banner hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cookie-banner-title"
  aria-live="polite"
  tabindex="-1"
>
  <div class="container mx-auto flex max-w-[1300px] flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div class="max-w-3xl">
      <p id="cookie-banner-title" class="mana-cookie-banner__title">
        Pliki cookies i płatności
      </p>
      <p class="mana-cookie-banner__text">
        Używamy niezbędnych cookies oraz narzędzi płatności Stripe. Szczegóły w
        <a href="/polityka-cookies" class="mana-link">polityce cookies</a>.
      </p>
    </div>
    <div class="flex shrink-0 flex-wrap gap-3">
      <button type="button" id="cookie-accept" class="mana-btn-solid px-5 py-3">
        Akceptuję
      </button>
      <a href="/polityka-cookies" class="mana-btn-outline mana-btn-outline-dark px-5 py-3">
        Ustawienia
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var banner = document.getElementById("cookie-banner");
    var accept = document.getElementById("cookie-accept");
    if (!banner || !accept) return;
    if (localStorage.getItem("gdd_cookie_consent") === "accepted") return;

    banner.classList.remove("hidden");
    banner.focus();

    function hideBanner() {
      banner.classList.add("hidden");
    }

    accept.addEventListener("click", function () {
      localStorage.setItem("gdd_cookie_consent", "accepted");
      hideBanner();
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && !banner.classList.contains("hidden")) {
        hideBanner();
      }
    });
  })();
</script>
