---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  class?: string;
  sizes?: string;
  widths?: number[];
  quality?: number;
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  width,
  height,
  loading = "lazy",
  decoding,
  class: className,
  sizes,
  widths,
  quality,
  fetchpriority,
} = Astro.props;

const isImported = typeof src === "object" && src !== null && "format" in src;
const inferSize = !isImported && (!width || !height);
---

{
  isImported ? (
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      class={className}
      sizes={sizes}
      widths={widths}
      quality={quality}
      fetchpriority={fetchpriority}
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      width={width}
      height={height}
      inferSize={inferSize}
      loading={loading}
      decoding={decoding}
      class={className}
      sizes={sizes}
      widths={widths}
      quality={quality}
      fetchpriority={fetchpriority}
    />
  )
}
