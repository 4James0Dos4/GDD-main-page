---
export const prerender = true;

import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ManaHero from "../components/mana/ManaHero.astro";
import ManaGoalsGrid from "../components/mana/ManaGoalsGrid.astro";
import ManaEventsList from "../components/mana/ManaEventsList.astro";
import ManaArticlesCta from "../components/mana/ManaArticlesCta.astro";
import ManaSupportStrip from "../components/mana/ManaSupportStrip.astro";
import ManaGallery from "../components/mana/ManaGallery.astro";
import { homeHeroAssets } from "../data/gddHome";
import { getWpArticles, getWpEvents } from "../lib/wordpress";

const [wpEvents, wpArticles, lcpHero] = await Promise.all([
  getWpEvents({ limit: 3 }),
  getWpArticles({ limit: 3 }),
  getImage({
    src: homeHeroAssets.heroImage,
    width: 960,
    format: "webp",
    quality: 75,
  }),
]);
---

<BaseLayout title="Strona główna" ogImage="/og-default.jpg" lcpImage={lcpHero.src}>
  <ManaHero />
  <ManaGoalsGrid />
  <ManaEventsList events={wpEvents} />
  <ManaArticlesCta articles={wpArticles} />
  <ManaSupportStrip />
  <ManaGallery />
</BaseLayout>
